{
  "manifest_version": 3,
  "name": "Tomorin New Tab",
  "version": "0.1.35",
  "description": "A lightweight local-first new tab page with search, shortcuts, pagination, and custom wallpaper.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "favicon", "search"],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
